{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "configMigration": true,
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^\\.github/workflows/.*\\.yaml$/"
      ],
      "matchStrings": [
        "autogov-version:[\\s\\S]*?default:\\s*(?<currentValue>v\\d+\\.\\d+\\.\\d+)"
      ],
      "depNameTemplate": "liatrio/autogov",
      "datasourceTemplate": "github-releases"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^README\\.md$/"
      ],
      "matchStrings": [
        "autogov-version`.*?default: '(?<currentValue>v\\d+\\.\\d+\\.\\d+)'"
      ],
      "depNameTemplate": "liatrio/autogov",
      "datasourceTemplate": "github-releases"
    }
  ],
  "packageRules": [
    {
      "extends": [
        ":semanticPrefixFixDepsChoreOthers",
        "helpers:pinGitHubActionDigests"
      ],
      "matchDepTypes": [
        "action"
      ],
      "pinDigests": true,
      "groupName": "GitHub Actions",
      "groupSlug": "github-actions"
    }
  ],
  "schedule": [
    "before 5am every weekday"
  ],
  "labels": [
    "renovate",
    "gha"
  ]
}
